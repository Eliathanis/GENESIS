[autoload]

; Global singletons
NetworkManager="*res://scripts/singletons/network_manager.gd"
GameState="*res://scripts/singletons/game_state.gd"
UIManager="*res://scripts/singletons/ui_manager.gd"

[debug]

gdscript/warnings/enable=true
gdscript/warnings/treat_warnings_as_errors=false

[editor_plugins]

enabled=PoolStringArray( "EditorImportGodotTs" )

[filesystem]

import/blender/enabled=true
import/fbx/enabled=true
import/gltf/enabled=true